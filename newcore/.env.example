# ═══════════════════════════════════════════════════════════════
# OpenGravity Engine — Configuration
# ═══════════════════════════════════════════════════════════════

# Server
PORT=3777
HOST=0.0.0.0

# Logging
LOG_LEVEL=info

# ── LLM Provider API Keys (all optional — mock provider works without any) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Default Model ──
# Options: mock, openai:gpt-4o, anthropic:claude-sonnet-4-20250514, gemini:gemini-2.5-flash, ollama:llama3
DEFAULT_MODEL=gemini:gemini-2.5-flash

# ── Workspace ──
WORKSPACE_ROOT=./workspaces
ARTIFACTS_DIR=./artifacts
AUDIT_DB_PATH=./data/audit.db

# ── Policy ──
ALLOW_NETWORK_REQUESTS=false
ALLOW_SYSTEM_PACKAGES=false
MAX_COMMAND_TIMEOUT_MS=30000
MAX_FILE_SIZE_BYTES=10485760

# ── Z3 Solver ──
Z3_ENABLED=true
Z3_TIMEOUT_MS=5000
